{
    "name": "alphpaca/stack",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Jacob Tobiasz",
            "email": "jacob@alphpaca.io"
        }
    ],
    "require": {
        "php": "^8.3",
        "symfony/http-kernel": "^6.4"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.23",
        "friendsofphp/php-cs-fixer": "^3.57",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^11.1",
        "shipmonk/composer-dependency-analyser": "^1.5",
        "symfony/config": "^6.4",
        "symfony/dependency-injection": "^6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/routing": "^6.4",
        "symplify/monorepo-builder": "^11.2"
    },
    "autoload": {
        "psr-4": {
            "Alphpaca\\Contracts\\Resource\\": "contracts/Resource/src/",
            "Alphpaca\\ResourceBundle\\": "symfony/ResourceBundle/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Tests\\Alphpaca\\ResourceBundle\\": "symfony/ResourceBundle/tests/"
        }
    },
    "replace": {
        "alphpaca/resource-bundle": "self.version",
        "alphpaca/resource-contracts": "self.version"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
